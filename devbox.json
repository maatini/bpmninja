{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.0/.schema/devbox.schema.json",
  "packages": [
    "rustup@latest",
    "gcc@latest",
    "rust-analyzer@latest",
    "nats-server@latest",
    "natscli@latest",
    "nodejs@latest"
  ],
  "shell": {
    "init_hook": [
      "rustup default stable 2>/dev/null",
      "echo '🦀 Rust toolchain ready: '$(rustc --version)"
    ],
    "scripts": {
      "build": [
        "cargo build --workspace"
      ],
      "lint": [
        "cargo clippy --workspace -- -D warnings"
      ],
      "fmt": [
        "cargo fmt --all --check"
      ],
      "test": [
        "cargo test --workspace"
      ],
      "run": [
        "cargo run --workspace"
      ],
      "nats:up": [
        "docker compose up -d"
      ],
      "nats:down": [
        "docker compose down"
      ],
      "nats:logs": [
        "docker compose logs -f nats"
      ],
      "test:nats": [
        "devbox run nats:up",
        "sleep 2",
        "cargo test --workspace",
        "devbox run nats:down"
      ],
      "test:nats:ci": [
        "devbox run nats:up",
        "sleep 5",
        "cargo test --workspace -- --ignored",
        "devbox run nats:down"
      ],
      "ui:dev": [
        "cd desktop-tauri && npm install && npm run tauri dev"
      ]
    }
  }
}